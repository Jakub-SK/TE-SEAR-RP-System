@model ErrorViewModel
@{
    ViewData["Title"] = "Error D:";
}

<h1 class="text-danger">@Localizer["Error"]</h1>

@if (Model.ShowUUID)
{
    <div>
        <strong>@Localizer["Track UUID"]:</strong>
        <code>@Model.UUID</code>
        <br />
        @Localizer["ID Track Message"]
        <br />
        <strong>@Localizer["Error Type"]:</strong>
        <code>@Model.ExceptionType</code>
        @if (Model.ExceptionType == "Unknown")
        {
            <div>
                @Localizer["Error Type Unknown"]
            </div>
        }
    </div>
    <br />
    <p>@Localizer["Input Steps"]</p>
    @using (Html.BeginForm("SubmitExceptionSteps", "Home", FormMethod.Post, new { @class = "form-horizontal" }))
    {
        <textarea asp-for="ErrorSteps" rows="10" columns="20" class="form-control" placeholder="@Localizer["Enter Steps here"]" maxlength="2000"></textarea>
        @Html.HiddenFor(Model => Model.UUID)
        <button type="submit">@Localizer["Submit Error Steps"]</button>
    }
    if (SEAR_DataContract.Misc.Misc.CheckIsDevelopmentEnvironment() && !string.IsNullOrEmpty(Model.StackTrace))
    {
        <br />
        <h1 class="text-danger">Exception Message:</h1>
        <div>@Model.Message</div>
        <br />
        <h1 class="text-danger">@Localizer["Exception Stack Trace"]:</h1>
        <div>@Model.StackTrace</div>
    }
}
else
{
    <p><strong>@Localizer["Unable to get tracking UUID"]</strong></p>
    <p>@Localizer["Unknown Error"]</p>
    <div>did you just accessed this page directly?! >:(</div>
}