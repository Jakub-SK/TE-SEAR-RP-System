                                <td>6m</td>
                                <td>Stomp</td>
                                <td><span class="dice">2d6</span><br>Impact</td>
                                <td>+3</td>
                            </tr>
    
                            <tr>
                                <td>Weight</td>
                                <td colspan="4">Medium</td>
                            </tr>
    
                            <tr>
                                <td>Size</td>
                                <td colspan="4">Medium</td>
                            </tr>
    
                        </table>
                    </div>
                </div>
        </div>

